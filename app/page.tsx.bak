                        <p className="mt-1">
                          Cover: {venue.tonightEvent?.cover_price || "Varies"}
                          {venue.tonightEvent?.start_time
                            ? ` • Starts: ${venue.tonightEvent.start_time}`
                            : ""}
                        </p>

                        <p className="mt-1 text-white/40">
                          {venue.voteCount || 0} active •{" "}
                          {minutesAgo(venue.lastUpdated)}
